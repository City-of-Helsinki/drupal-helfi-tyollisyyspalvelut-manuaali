@@ -80,12 +97,48 @@ class RequireOnPublishValidator extends ConstraintValidator implements Container
     // If the entity is a paragraph, we need to determine the publish status of
     // its parent entity.
     if ($this->moduleHandler->moduleExists('paragraphs') && $entity->getEntityTypeId() == 'paragraph') {
-      if ($this->request) {
-        $status = $this->request->request->all()['status'] ?? ['value' => 0];
-        $is_published = $status['value'];
+      // Grab the parent entity of the paragraph.
+      $parent = $entity->getParentEntity();
+      if (!$parent) {
+        return;
       }
-      else {
-        $is_published = $entity->getParentEntity()->isPublished();
+
+      // Default to the current saved state.
+      $is_published = $parent->isPublished();
+
+      // Check if the parent entity is under content moderation.
+      if ($this->moderationInfo && $this->moderationInfo->isModeratedEntity($parent)) {
+        // Only check moderation state from the request if we're in a POST web request.
+        if (
+          PHP_SAPI !== 'cli' &&
+          $this->request &&
+          $this->request->getMethod() === 'POST' &&
+          ($moderation_state = $this->request->get('moderation_state'))
+        ) {
+          if (is_array($moderation_state) && isset($moderation_state[0]['state'])) {
+            // Check that the given moderation state is a "Published" state.
+            $workflow = $this->moderationInfo->getWorkflowForEntity($parent);
+            /* @var \Drupal\content_moderation\ContentModerationState $new_state */
+            $new_state = $workflow?->getTypePlugin()->getState($moderation_state[0]['state']);
+            if ($new_state) {
+              $is_published = $new_state->isPublishedState();
+            }
+          }
+        }
+      }
+
+      // If not using moderation, check the raw 'status' field from the request
+      // form submission. This ensures we capture an intent to publish or
+      // unpublish that hasn't been saved yet.
+      if (
+        PHP_SAPI !== 'cli' &&
+        $this->request &&
+        $this->request->getMethod() === 'POST'
+      ) {
+        $status = $this->request->get('status');
+        if (is_array($status) && array_key_exists('value', $status)) {
+          $is_published = (bool) $status['value'];
+        }
       }
     }
 
