+    parent::setUp();
+
+    $this->installEntitySchema('node');
+    $this->installEntitySchema('user');
+    $this->installSchema('system', ['sequences']);
+
+    NodeType::create([
+      'type' => 'article',
+      'name' => 'Article',
+    ])->save();
+
+    // Create a field.
+    FieldStorageConfig::create([
+      'field_name' => 'field_rop_text',
+      'entity_type' => 'node',
+      'type' => 'text',
+      'cardinality' => 1,
+      'settings' => [],
+    ])->save();
+
+    FieldConfig::create([
+      'field_name' => 'field_rop_text',
+      'entity_type' => 'node',
+      'bundle' => 'article',
+      'label' => 'Required on publish text',
+      'required' => FALSE,
+      'third_party_settings' => [
