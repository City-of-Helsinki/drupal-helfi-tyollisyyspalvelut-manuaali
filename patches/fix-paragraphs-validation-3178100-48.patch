+class RequireOnPublishValidatorTest extends KernelTestBase {
+
+  /**
+   * {@inheritdoc}
+   */
+  protected static $modules = [
+    'node',
+    'user',
+    'field',
+    'text',
+    'filter',
+    'system',
+    'require_on_publish',
+  ];
+
+  /**
+   * {@inheritdoc}
