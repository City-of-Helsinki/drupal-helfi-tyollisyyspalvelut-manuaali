+      'settings' => [
+        'target_type' => 'paragraph',
+        'handler' => 'default:paragraph',
+      ],
+    ])->save();
+
+    // Attach editorial workflow to node.article.
+    $workflow = $this->createEditorialWorkflow();
+    $this->addEntityTypeAndBundleToWorkflow($workflow, 'node', 'article');
+    $workflow->save();
+
+    // Give ourselves the “publish” and “create_new_draft” permissions.
+    $this->setCurrentUser($this->createUser([
+      'use editorial transition publish',
+      'use editorial transition create_new_draft',
+    ]));
+  }
+
+  /**
+   * Helper to create a moderated node with one paragraph.
+   *
+   * @param string|null $val1
+   *   Value for field_subnote1, or NULL.
+   * @param string|null $val2
+   *   Value for field_subnote2, or NULL.
+   * @param string $state
+   *   Moderation state: 'draft' or 'published'.
+   *
+   * @return \Drupal\node\Entity\Node
+   *   The created node.
+   */
+  private function createNodeWithParagraph(?string $val1 = NULL, ?string $val2 = NULL, string $state = 'draft'): Node {
+    $node = Node::create([
+      'type' => 'article',
+      'title' => 'Moderated note',
+    ]);
+
+    $paragraph = Paragraph::create([
+      'type'           => 'note',
+      'field_subnote1' => $val1,
+      'field_subnote2' => $val2,
+    ]);
+    $paragraph->save();
+
+    // Reference it with both target_id and target_revision_id.
+    $node->set('field_note', [
+      [
+        'target_id' => $paragraph->id(),
+        'target_revision_id' => $paragraph->getRevisionId(),
+      ],
+    ]);
+
+    $node->moderation_state->value = $state;
+    $node->save();
+
+    return $node;
+  }
+
+  /**
+   * Draft parent → only warn_on_empty should fire (no violations).
+   */
+  public function testDraftParagraphWarning(): void {
+    $node = $this->createNodeWithParagraph(NULL, NULL, 'draft');
+    $violations = $node->validate();
+    $this->assertCount(0, $violations, 'Draft parent causes no ROP violations.');
+
+    // But a warning was emitted for Sub Note 2.
+    $warnings = $this->container->get('messenger')->messagesByType('warning');
+    $this->assertStringContainsString('Sub Note 2 may be empty until publishing.', reset($warnings));
+  }
+
+  /**
+   * Published parent → require_on_publish should produce a violation.
+   */
+  public function testPublishedParentTriggersParagraphViolation(): void {
+    $node = $this->createNodeWithParagraph(NULL, NULL, 'published');
+    $violations = $node->validate();
+
+    $this->assertCount(1, $violations, 'Published parent with missing sub-fields produces one violation.');
+
+    $messages = array_map(fn($v) => $v->getMessage()->render(), iterator_to_array($violations));
+    $this->assertStringContainsString('Sub Note 1 field is required when publishing.', reset($messages));
+  }
+
+  /**
+   * Published parent with both sub-fields filled → no violations.
+   */
+  public function testPublishedParentWithParagraphFilledPasses(): void {
+    $node = $this->createNodeWithParagraph('foo', 'bar', 'published');
+    $violations = $node->validate();
+    $this->assertCount(0, $violations, 'Published parent with all sub-fields filled passes validation.');
+  }
+
+}
