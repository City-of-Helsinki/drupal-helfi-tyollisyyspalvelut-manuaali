{#
/**
 * @file
 * Theme override to display a block.
 *
 * Available variables:
 * - content: The content of this block.
 *
 * @see template_preprocess_block()
 */
#}

<div class='node-service-edit-form-pager node-form prevent-scroll'>
  <div class='stepper multistep-nav-wrapper'>
    <div class="stepper-wrapper">
      <div class="step-lines">
        <div class="step-line"></div>
        <div class="step-line"></div>
        <div class="step-line"></div>
      </div>
    </div>
    <button id='step-1' data-step=0 class="step nav-step-0 multistep-nav" aria-label="{{ 'Step 1. Step 1/4'|t }}"><div class='nav-icon'>1</div><div class='label'>{{'Basic information'|t}}</div></button>
    <button id='step-2' data-step=1 class="step nav-step-1 multistep-nav" aria-label="{{ 'Step 2. Step 2/4'|t }}"><div class='nav-icon'>2</div><div class='label'>{{'Place and time'|t}}</div></button>
    <button id='step-3' data-step=2 class="step nav-step-2 multistep-nav" aria-label="{{ 'Step 3. Step 3/4'|t }}"><div class='nav-icon'>3</div><div class='label'>{{'Description and work instructions'|t}}</div></button>
    <button id='step-4' data-step=3 class="step nav-step-3 multistep-nav" aria-label="{{ 'Step 4. Step 4/4'|t }}"><div class='nav-icon'>4</div><div class='label'>{{'Additional information'|t}}</div></button>
  </div>
</div>
